APP_NAME=Momo Blog API
APP_VERSION=0.1.0
APP_ENV=production
DEBUG=false
API_V1_PREFIX=/api
DOCS_URL=
REDOC_URL=
OPENAPI_URL=
DATABASE_URL=postgresql+psycopg://postgres:strong-password@127.0.0.1:5432/momo_blog
CORS_ORIGINS=https://blog.example.com,https://admin.example.com
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440
UPLOAD_DIR=/var/www/momo_blog/uploads
SITE_URL=https://blog.example.com
